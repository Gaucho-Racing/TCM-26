FROM python:3.12-slim-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

WORKDIR /app
COPY pyproject.toml ./
RUN uv pip install --system . watchdog

CMD ["watchmedo", "auto-restart", \
     "--directory=/app", \
     "--pattern=*.py", \
     "--recursive", \
     "--", \
     "python", "main.py"]
