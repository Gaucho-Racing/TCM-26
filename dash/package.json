{
  "name": "gr26-dash",
  "version": "1.0.5",
  "description": "GR26 on-vehicle dashboard for the driver display",
  "main": "./out/main/index.js",
  "type": "module",
  "author": {
    "name": "Gaucho Racing",
    "email": "team@gauchoracing.com",
    "url": "https://gauchoracing.com"
  },
  "homepage": "https://github.com/Gaucho-Racing/TCM-26",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gaucho-Racing/TCM-26.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:linux": "electron-vite build && electron-builder --linux --arm64 --publish never",
    "build:linux-x64": "electron-vite build && electron-builder --linux --x64 --publish never",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.0.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.13.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0"
  }
}
