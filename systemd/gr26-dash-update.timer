[Unit]
Description=Periodic gr26-dash auto-update check
Documentation=https://github.com/Gaucho-Racing/TCM-26

[Timer]
# Fire 1 min after boot — gives the network and NTP time to actually
# come up. Trying at 10s was too eager; the update would always fail
# the first time on a freshly booted car. After that, every 15 min so
# a car that boots offline (no wifi yet, or short session) still has
# multiple chances to pick up a new release within a typical session.
OnBootSec=1min
OnUnitActiveSec=15min
# No Persistent=true on purpose: OnBootSec already guarantees a fire 1 min
# after every boot, and the car is typically powered off for long stretches.
# Replaying every missed 15-min interval at boot would just be a stack of
# redundant "already up to date" checks against the same release.

[Install]
WantedBy=timers.target
