FROM golang:1.26-bookworm

# python3 + jtop for jetson-stats.py runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*
RUN python3 -m pip install --break-system-packages -U jetson-stats

RUN go install github.com/air-verse/air@latest

WORKDIR /app/mqtt

CMD ["air", "-c", ".air.toml"]
