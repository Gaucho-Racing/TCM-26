# Copy the contents of this file to `.env`

ENV="DEV"

VEHICLE_ID="GR26"
VEHICLE_UPLOAD_KEY="0"

DATABASE_HOST="db"
DATABASE_PORT="5432"
DATABASE_NAME="tcm26"
DATABASE_USER="postgres"
DATABASE_PASSWORD="password"

# Local MQTT broker — always required.
# Inside the docker network this is the `nanomq` service.
LOCAL_MQTT_HOST="nanomq"
LOCAL_MQTT_PORT="1883"
LOCAL_MQTT_USER=""
LOCAL_MQTT_PASSWORD=""

# Cloud MQTT broker — optional. Leave CLOUD_MQTT_HOST empty to disable
# dual-publish; the relay will publish to LOCAL only.
#
# To test against the Mapache stack running on this host, set:
#   CLOUD_MQTT_HOST="host.docker.internal"
#   CLOUD_MQTT_PORT="1883"
CLOUD_MQTT_HOST=""
CLOUD_MQTT_PORT="1883"
CLOUD_MQTT_USER=""
CLOUD_MQTT_PASSWORD=""

CAN_PORT="8000"

# Per-CAN-ID publish throttle in ms — separate for each broker.
# Local fast for the dash, cloud cellular-friendly.
LOCAL_PUBLISH_INTERVAL="20"
CLOUD_PUBLISH_INTERVAL="100"

PING_INTERVAL="5000"
