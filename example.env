# Copy to `.env` and edit per-deployment. Anything not in here uses the
# defaults baked into docker-compose.yml.

ENV="DEV"

# Per-vehicle identity
VEHICLE_ID="GR26"
VEHICLE_UPLOAD_KEY="0"

# Postgres password — change for production
DATABASE_PASSWORD="password"

# Cloud MQTT broker — leave empty to disable dual-publish.
# To test against a Mapache stack on this host, use host.docker.internal:1883.
CLOUD_MQTT_HOST=""
CLOUD_MQTT_PORT="1883"
CLOUD_MQTT_USER=""
CLOUD_MQTT_PASSWORD=""

# Per-CAN-ID publish throttle in ms (per broker).
LOCAL_PUBLISH_INTERVAL="20"
CLOUD_PUBLISH_INTERVAL="100"
